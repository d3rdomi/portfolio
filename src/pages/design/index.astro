---
import BaseHead from '../../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import '../../styles/global-style.css';
import '../../styles/design-style.css';
import MyFooter from '../../components/MyFooter.astro';
import Navbar from '../../components/Navbar.astro';
const posts = (await getCollection('design')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

	</head>
	<body>
		<Navbar class="navbar" />
		<div class="header">
			<h1>Design</h1>
		</div>

		<main>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/design/${post.slug}/`}>
									{post.data.thumbnail && <img src={post.data.thumbnail} alt={post.data.altText ?? ''} />}

									<h4 class="title">{post.data.title}</h2>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<MyFooter />
	</body>
</html>
