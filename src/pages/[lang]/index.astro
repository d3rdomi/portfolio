---
import BaseHead from '../../components/BaseHead.astro';
import '../../styles/global-style.css';
import '../../styles/index-style.css';
import MyFooter from '../../components/MyFooter.astro';
import LangSwitch from '../../components/LangSwitch.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Home-Daten (Portrait + Tagline) aus Keystatic laden
const homeData = await getEntry('home', 'index');
const { portrait, headingEn } = homeData.data;
const { Content } = await homeData.render();

// Englische Tagline aus headingEn (Frontmatter); leer → deutscher Markdoc-Body (<Content />).
const showGermanHeading = lang === 'de' || !headingEn || headingEn.trim() === '';
---

<!doctype html>
<html lang={lang}>
<head>
	<script>
		import "../../scripts/gradient.js";
	</script>
	<BaseHead title={t('site.title')} description={t('site.description')} lang={lang} />
	<link rel="icon" type="image/x-icon" href="/favicon.svg">
	<link rel="icon" type="image/png" href="/favicon.png">
</head>

	<body>

		<canvas id="gradient-canvas" data-transition-in></canvas>

		<LangSwitch />

		<div class="main-grid">

			<div class="hero-text">
				<h1>Dominik <br> Lange</h1>
				<div class="divider"></div>
				<div class="subtitle">
					{showGermanHeading ? <Content /> : <p>{headingEn}</p>}
				</div>
			</div>

			<div class="hero-portrait">
				<img src={portrait} alt={t('about.portraitAlt')} />
			</div>

			<div class="nav-buttons">

				<a class="about-me article-section nav-button" href={localizePath(lang, '/about-me')}>
					<h2>{t('home.about')}</h2>
				</a>

				<a class="design article-section nav-button" href={localizePath(lang, '/design')}>
					<h2>{t('home.design')}</h2>
				</a>

				<a class="animation article-section nav-button" href={localizePath(lang, '/concepts')}>
					<h2>{t('home.concepts')}</h2>
				</a>

				<a class="photography article-section nav-button" href={localizePath(lang, '/photography')}>
					<h2>{t('home.photography')}</h2>
				</a>

			</div>

			<MyFooter class="footer"/>

		</div>
	</body>
</html>
