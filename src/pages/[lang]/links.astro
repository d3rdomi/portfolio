---
import '../../styles/links/style.css';
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/assets/links/favicon.svg" type="image/svg+xml" />
  <link href="https://fonts.googleapis.com/css2?family=Silkscreen&display=swap" rel="stylesheet" />
  <title>Poolsuite FM</title>
</head>
<body>

  <div class="page">
    <div class="container">

      <!-- Header window -->
      <header class="header">
        <div class="header-titlebar">
          <span class="titlebar-dot"></span>
          <span class="titlebar-dot"></span>
          <span class="titlebar-dot"></span>
        </div>
        <div class="teal-bar"></div>
        <div class="header-body">
          <span class="logo-emoji">🌴</span>
          <div class="site-title">Poolsuite FM</div>
          <div class="site-subtitle">The Grand Vacation — Now Playing Everywhere</div>
        </div>
      </header>

      <!-- Link cards -->
      <div class="links">

        <a href="https://poolsuite.net" target="_blank" rel="noopener" class="link-card">
          <div class="card-titlebar">
            <span class="card-titlebar-dot"></span>
            <span class="card-titlebar-dot"></span>
            <span class="card-titlebar-dot"></span>
          </div>
          <div class="card-body">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </div>
            <div class="card-text">
              <div class="card-label">Website</div>
              <div class="card-meta">poolsuite.net</div>
            </div>
            <div class="card-arrow">→</div>
          </div>
        </a>

        <a href="https://apps.apple.com/app/poolsuite-fm/id1514817810" target="_blank" rel="noopener" class="link-card">
          <div class="card-titlebar">
            <span class="card-titlebar-dot"></span>
            <span class="card-titlebar-dot"></span>
            <span class="card-titlebar-dot"></span>
          </div>
          <div class="card-body">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
            </div>
            <div class="card-text">
              <div class="card-label">iOS App</div>
              <div class="card-meta">App Store</div>
            </div>
            <div class="card-arrow">→</div>
          </div>
        </a>

        <a href="https://play.google.com/store/apps/details?id=net.poolsuite.mobile" target="_blank" rel="noopener" class="link-card">
          <div class="card-titlebar">
            <span class="card-titlebar-dot"></span>
            <span class="card-titlebar-dot"></span>
            <span class="card-titlebar-dot"></span>
          </div>
          <div class="card-body">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M22.018 13.298l-3.919 2.218-3.515-3.493 3.543-3.521 3.891 2.202a1.49 1.49 0 0 1 0 2.594zM1.337.924a1.486 1.486 0 0 0-.112.568v21.017c0 .217.045.419.124.6l11.155-11.087L1.337.924zm12.207 10.065l3.258-3.238L3.45.195a1.466 1.466 0 0 0-.946-.179l11.04 10.973zm0 2.067l-11 10.933c.298.036.612-.016.906-.183l13.324-7.54-3.23-3.21z"/>
              </svg>
            </div>
            <div class="card-text">
              <div class="card-label">Android App</div>
              <div class="card-meta">Google Play</div>
            </div>
            <div class="card-arrow">→</div>
          </div>
        </a>

      </div>

      <footer class="footer">☼ poolsuite.net ☼</footer>

    </div>
  </div>

</body>
</html>
