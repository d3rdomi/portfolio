---
import BaseHead from '../../../components/BaseHead.astro';
import { getCollection, getEntry } from 'astro:content';
import '../../../styles/global-style.css';
import '../../../styles/design-style.css';
import MyFooter from '../../../components/MyFooter.astro';
import Navbar from '../../../components/Navbar.astro';
import { getLangFromUrl, useTranslations, localizePath, pick } from '../../../i18n/utils';
import LangSwitch from '../../../components/LangSwitch.astro';
import MobileNav from '../../../components/MobileNav.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const posts = (await getCollection('design')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const downloadsEntry = await getEntry('portfolio-downloads', 'index');
const pdfUrl = lang === 'en'
	? (downloadsEntry?.data.pdfEn || downloadsEntry?.data.pdfDe || null)
	: (downloadsEntry?.data.pdfDe || null);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={t('site.title')} description={t('site.description')} lang={lang} />
	</head>
	<body>
		<MobileNav />
		<LangSwitch />
		<Navbar class="navbar" />
		<div class="header">
			<h1>{t('heading.design')}</h1>
			{pdfUrl && (
				<a href={pdfUrl} download class="download-btn">
					{t('design.downloadPdf')}
				</a>
			)}
		</div>

		<main>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={localizePath(lang, `/design/${post.slug}/`)}>
									{post.data.thumbnail && <img src={post.data.thumbnail} alt={pick(post.data.altText, lang)} />}

									<h4 class="title">{post.data.title}</h4>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<MyFooter />
	</body>
</html>
