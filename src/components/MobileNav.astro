---
import { getLangFromUrl, useTranslations, localizePath, getAlternatePath } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const path = Astro.url.pathname.replace(/^\/(de|en)(?=\/|$)/, '') || '/';
---

<button class="burger-btn" id="burger-btn" aria-label="Menü öffnen">
  <i class="fa-solid fa-bars"></i>
</button>

<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true">
  <div class="overlay-inner">
    <div class="overlay-header">
      <span class="overlay-title">Dominik Lange</span>
      <button class="close-btn" id="close-btn" aria-label="Menü schließen">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <nav class="overlay-nav">
      <a href={localizePath(lang, '/')} class={`nav-pill ${path === '/' ? 'active' : ''}`}>
        <span>{t('nav.home')}</span>
        <i class="fa-solid fa-house"></i>
      </a>
      <a href={localizePath(lang, '/about-me')} class={`nav-pill ${path.startsWith('/about-me') ? 'active' : ''}`}>
        <span>{t('nav.about')}</span>
        <i class="fa-solid fa-face-smile-beam"></i>
      </a>
      <a href={localizePath(lang, '/design')} class={`nav-pill ${path.startsWith('/design') ? 'active' : ''}`}>
        <span>{t('nav.design')}</span>
        <i class="fa-solid fa-palette"></i>
      </a>
      <a href={localizePath(lang, '/concepts')} class={`nav-pill ${path.startsWith('/concepts') ? 'active' : ''}`}>
        <span>{t('nav.concepts')}</span>
        <i class="fa-solid fa-lightbulb"></i>
      </a>
      <a href={localizePath(lang, '/photography')} class={`nav-pill ${path.startsWith('/photography') ? 'active' : ''}`}>
        <span>{t('nav.photography')}</span>
        <i class="fa-solid fa-camera"></i>
      </a>
    </nav>

    <div class="overlay-lang-switch">
      {languages.map((l) => (
        <a
          href={getAlternatePath(Astro.url, l)}
          hreflang={l}
          class={`lang-btn ${l === lang ? 'active' : ''}`}
          aria-current={l === lang ? 'true' : undefined}
        >
          {l.toUpperCase()}
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  function initMobileNav() {
    const burgerBtn = document.getElementById('burger-btn');
    const closeBtn = document.getElementById('close-btn');
    const overlay = document.getElementById('mobile-overlay');

    if (!burgerBtn || !closeBtn || !overlay) return;

    const o = overlay!;

    let savedScrollY = 0;

    function openMenu() {
      savedScrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${savedScrollY}px`;
      document.body.style.width = '100%';
      o.classList.add('open');
      o.setAttribute('aria-hidden', 'false');
    }

    function closeMenu() {
      o.classList.remove('open');
      o.setAttribute('aria-hidden', 'true');
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      window.scrollTo(0, savedScrollY);
    }

    burgerBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    o.addEventListener('click', (e) => {
      if (e.target === o) closeMenu();
    });
  }

  document.addEventListener('astro:page-load', initMobileNav);
</script>

<style>
  .burger-btn {
    display: none;
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 300;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    border: none;
    background-color: #ffffff;
    cursor: pointer;
    font-size: 1.1rem;
    color: #000;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
    transition: background-color 0.2s ease;
  }

  .burger-btn:hover {
    background-color: #e8e8e8;
  }

  @media (max-width: 767px) {
    .burger-btn {
      display: flex;
    }
  }

  .mobile-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 500;
    background-color: rgba(110, 110, 110, 0.4);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  .mobile-overlay.open {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .overlay-inner {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    width: 100%;
    padding: 2rem 1.25rem 2rem;
    box-sizing: border-box;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .overlay-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
  }

  .overlay-title {
    font-family: 'Unbounded', sans-serif;
    font-weight: 700;
    font-size: 1.55rem;
    color: #fff;
  }

  .close-btn {
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    border: none;
    background-color: #ffffff;
    cursor: pointer;
    font-size: 1.1rem;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease;
    flex-shrink: 0;
  }

  .close-btn:hover {
    background-color: #e8e8e8;
  }

  .overlay-nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
    justify-content: center;
  }

  .nav-pill {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 1.4rem 0 2rem;
    border-radius: 5rem;
    background-color: rgba(200, 200, 200, 0.22);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-decoration: none;
    color: #fff;
    font-family: 'Roboto', sans-serif;
    font-size: 1.15rem;
    line-height: 1;
    font-weight: 500;
    transition: background-color 0.2s ease;
    width: 100%;
    box-sizing: border-box;
    min-width: 0;
  }

  .nav-pill i {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-left: 0.5rem;
  }

  .nav-pill.active {
    background-color: #ffffff;
    color: #000;
  }

  .nav-pill:not(.active):hover {
    background-color: rgba(200, 200, 200, 0.35);
  }

  .overlay-lang-switch {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    background-color: rgba(200, 200, 200, 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.3rem;
    border-radius: 5rem;
    width: fit-content;
    margin: 2.5rem auto 0;
  }

  .lang-btn {
    display: grid;
    place-items: center;
    padding: 0.3rem 0.75rem;
    border-radius: 5rem;
    font-family: 'Roboto', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    line-height: 1;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .lang-btn.active {
    background-color: #ffffff;
    color: #000;
    border-radius: 5rem;
  }

  .lang-btn:not(.active):hover {
    background-color: rgba(200, 200, 200, 0.4);
  }
</style>
