---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global-style.css';
import { ClientRouter } from 'astro:transitions';
import { getLangFromUrl, getAlternatePath } from '../i18n/utils';
import { languages, defaultLang, type Lang } from '../i18n/ui';

interface Props {
	title: string;
	description: string;
	image?: string;
	lang?: Lang;
}

const { title, description, image = '/blog-placeholder-1.jpg', lang = getLangFromUrl(Astro.url) } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// hreflang-Alternativen für die jeweils andere Sprache (+ x-default = Deutsch).
const alternates = languages.map((l) => ({
	lang: l,
	href: new URL(getAlternatePath(Astro.url, l), Astro.site).href,
}));
const xDefault = new URL(getAlternatePath(Astro.url, defaultLang), Astro.site).href;
---

<ClientRouter />

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical & Sprach-Alternativen -->
<link rel="canonical" href={canonicalURL} />
{alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}
<link rel="alternate" hreflang="x-default" href={xDefault} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- FontAwesome (async, non-blocking) -->
<link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" onload="this.onload=null;this.rel='stylesheet'">
<noscript set:html={'<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">'} />

<!-- Font Import -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;600;700;800&family=Unbounded:wght@500&display=swap" rel="stylesheet">
