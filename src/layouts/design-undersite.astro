---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global-style.css';
import '../styles/design-undersite-style.css';
import MyFooter from '../components/MyFooter.astro';
import Carousel from '../components/Carousel.jsx';
import Navbar from '../components/Navbar.astro';

type Props = CollectionEntry<'design'>['data'];

const { title, pubDate, heroImageDesktop, heroImageMobile, ImageCarousel, backgroundColor, altText, blocks, copyright } = Astro.props;

const slides = (ImageCarousel ?? []).map((item) => ({
  title: item.title,
  image: item.image,
  text: item.text,
  alt: item.altText || item.title,
}));

---

<html lang="de">
  <head>
    <BaseHead title={title} description={title} />
  </head>

  <body style={`background-color: ${backgroundColor || '#000000'};`}>
    <Navbar />
    {(heroImageDesktop || heroImageMobile) && (
      <div class="hero-header">
        <picture>
          {heroImageMobile && <source media="(max-width: 767px)" srcset={heroImageMobile} />}
          <img src={heroImageDesktop || heroImageMobile} alt={altText || title} />
        </picture>
      </div>
    )}
    <main>
      <article>
        <div class="prose">
          <div class="title">
            <h1>{title}</h1>
          </div>

          <slot />

          {copyright && <p class="copyright">© {copyright}</p>}

          {slides.length > 0 && <Carousel slides={slides} client:load />}
        </div>
      </article>
    </main>
    <MyFooter />
  </body>
</html>
