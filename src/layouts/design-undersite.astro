---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global-style.css';
import '../styles/design-undersite-style.css';
import MyFooter from '../components/MyFooter.astro';
import Carousel from '../components/Carousel.jsx';
import Navbar from '../components/Navbar.astro';
import { getLangFromUrl, pick } from '../i18n/utils';
import LangSwitch from '../components/LangSwitch.astro';

type Props = CollectionEntry<'design'>['data'];

const lang = getLangFromUrl(Astro.url);
const { title, heroImageDesktop, heroImageMobile, ImageCarousel, backgroundColor, altText, blocks, copyright, contentEn, button } = Astro.props;
const buttonLink = button?.buttonLink;
const buttonLabel = button?.buttonLabel;

const slides = (ImageCarousel ?? []).map((item) => ({
  image: item.image,
  alt: pick(item.altText, lang),
}));

// Englischer Body kommt aus contentEn (Frontmatter); ist er leer, wird der deutsche
// Markdoc-Body (<slot />) als Fallback gezeigt.
const showGermanBody = lang === 'de' || !contentEn || contentEn.trim() === '';
const enParagraphs = (contentEn ?? '')
  .split(/\n\s*\n/)
  .map((s) => s.trim())
  .filter(Boolean);
---

<html lang={lang}>
  <head>
    <BaseHead title={title} description={title} lang={lang} />
  </head>

  <body style={`background-color: ${backgroundColor || '#000000'};`}>
    {/* <LangSwitch /> */}
    <Navbar />
    {(heroImageDesktop || heroImageMobile) && (
      <div class="hero-header">
        <picture>
          {heroImageMobile && <source media="(max-width: 767px)" srcset={heroImageMobile} />}
          <img src={heroImageDesktop || heroImageMobile} alt={pick(altText, lang) || title} />
        </picture>
      </div>
    )}
    <main>
      <article>
        <div class="prose">
          <div class="title">
            <h1>{title}</h1>
          </div>

          {showGermanBody ? <slot /> : enParagraphs.map((p) => <p>{p}</p>)}

          {buttonLink && buttonLink.trim() !== '' && (
            <a href={buttonLink} class="cta-button" target="_blank" rel="noopener noreferrer">
              {pick(buttonLabel, lang) || (lang === 'de' ? 'mehr erfahren' : 'learn more')}
            </a>
          )}

          {copyright && <p class="copyright">© {copyright}</p>}

          {slides.length > 0 && <Carousel slides={slides} client:load />}

          {blocks && blocks.length > 0 && (
            <div class="blocks-section">
              {blocks.map((block) => {
                if (block.discriminant === 'text') return (
                  <div class="text-block">
                    {pick(block.value.headline, lang) && <h2>{pick(block.value.headline, lang)}</h2>}
                    <p>{pick(block.value.content, lang)}</p>
                  </div>
                );
                if (block.discriminant === 'image') return (
                  <div class="image-block">
                    <img src={block.value.src} alt={pick(block.value.alt, lang)} />
                  </div>
                );
                if (block.discriminant === 'imageText') return (
                  <div class:list={['image-text-block', block.value.imagePosition]}>
                    <img src={block.value.image} alt={pick(block.value.alt, lang)} />
                    <div class="block-text">
                      <p>{pick(block.value.text, lang)}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </article>
    </main>
    <MyFooter />
  </body>
</html>
