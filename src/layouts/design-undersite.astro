---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global-style.css';
import '../styles/design-undersite-style.css';
import MyFooter from '../components/MyFooter.astro';
import Carousel from '../components/Carousel.jsx';
import Navbar from '../components/Navbar.astro';

type Props = CollectionEntry<'design'>['data'];

const { title, pubDate, heroImageDesktop, heroImageMobile, ImageCarousel, backgroundColor, altText, blocks, copyright } = Astro.props;

const slides = (ImageCarousel ?? []).map((item) => ({
  title: item.title,
  image: item.image,
  text: item.text,
  alt: item.altText || item.title,
}));

---

<html lang="de">
  <head>
    <BaseHead title={title} description={title} />
  </head>

  <body style={`background-color: ${backgroundColor || '#000000'};`}>
    <Navbar />
    {(heroImageDesktop || heroImageMobile) && (
      <div class="hero-header">
        <picture>
          {heroImageMobile && <source media="(max-width: 767px)" srcset={heroImageMobile} />}
          <img src={heroImageDesktop || heroImageMobile} alt={altText || title} />
        </picture>
      </div>
    )}
    <main>
      <article>
        <div class="prose">
          <div class="title">
            <h1>{title}</h1>
          </div>

          <slot />

          {copyright && <p class="copyright">© {copyright}</p>}

          {slides.length > 0 && <Carousel slides={slides} client:load />}

          {blocks && blocks.length > 0 && (
            <div class="blocks-section">
              {blocks.map((block) => {
                if (block.discriminant === 'text') return (
                  <div class="text-block">
                    {block.value.headline && <h2>{block.value.headline}</h2>}
                    <p>{block.value.content}</p>
                  </div>
                );
                if (block.discriminant === 'image') return (
                  <div class="image-block">
                    {block.value.headline && <h2>{block.value.headline}</h2>}
                    <img src={block.value.src} alt={block.value.alt ?? ''} />
                    {block.value.caption && <p class="caption">{block.value.caption}</p>}
                  </div>
                );
                if (block.discriminant === 'imageText') return (
                  <div class:list={['image-text-block', { reverse: block.value.imagePosition === 'right' }]}>
                    <img src={block.value.image} alt={block.value.alt ?? ''} />
                    <div class="block-text">
                      {block.value.headline && <h2>{block.value.headline}</h2>}
                      <p>{block.value.text}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </article>
    </main>
    <MyFooter />
  </body>
</html>
