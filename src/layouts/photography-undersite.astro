---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global-style.css';
import '../styles/photography-undersite-style.css';
import MyFooter from '../components/MyFooter.astro';
import Navbar from '../components/Navbar.astro';
import { getLangFromUrl, pick } from '../i18n/utils';
import LangSwitch from '../components/LangSwitch.astro';

type Props = CollectionEntry<'photography'>['data'];

const lang = getLangFromUrl(Astro.url);
const { title, heroImage, altText, text, images, contentEn } = Astro.props;

const description = pick(text, lang);
const heroAlt = pick(altText, lang) || title;

const showGermanBody = lang === 'de' || !contentEn || contentEn.trim() === '';
const enParagraphs = (contentEn ?? '')
	.split(/\n\s*\n/)
	.map((s) => s.trim())
	.filter(Boolean);
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description || title} lang={lang} />
	</head>

	<body>
		{/* <LangSwitch /> */}
		<Navbar />

		{heroImage && (
			<div class="hero-header">
				<img src={heroImage} alt={heroAlt} />
			</div>
		)}

		<main>
			<article>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
					</div>

					{description && (
						<div class="text-content">
							<p>{description}</p>
						</div>
					)}

					{images && images.length > 0 && (
						<div class="photo-grid">
							{images.map((src) => (
								<img src={src} alt={heroAlt} loading="lazy" />
							))}
						</div>
					)}

					{showGermanBody ? <slot /> : enParagraphs.map((p) => <p>{p}</p>)}
				</div>
			</article>
		</main>

		<MyFooter />
	</body>
</html>
